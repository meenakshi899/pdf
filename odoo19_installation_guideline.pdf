(sudo systemctl enable --now odoo19) Tj
T*
(sudo systemctl status odoo19) Tj
T*
(```) Tj
T*
() Tj
T*
(---) Tj
T*
() Tj
T*
(## 12\) Configure Nginx Reverse Proxy \(Recommended\)) Tj
T*
(Install Nginx:) Tj
T*
(```bash) Tj
T*
(sudo apt install -y nginx) Tj
T*
(```) Tj
T*
() Tj
T*
(Create `/etc/nginx/sites-available/odoo19`:) Tj
T*
() Tj
T*
(```nginx) Tj
T*
(server {) Tj
T*
(    listen 80;) Tj
T*
(    server_name your-domain.com;) Tj
T*
() Tj
T*
(    proxy_read_timeout 720s;) Tj
T*
(    proxy_connect_timeout 720s;) Tj
T*
(    proxy_send_timeout 720s;) Tj
T*
() Tj
T*
(    client_max_body_size 200m;) Tj
T*
() Tj
T*
(    location / {) Tj
T*
(        proxy_pass http://127.0.0.1:8069;) Tj
T*
(        proxy_set_header Host $host;) Tj
T*
(        proxy_set_header X-Real-IP $remote_addr;) Tj
T*
(        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;) Tj
T*
(        proxy_set_header X-Forwarded-Proto $scheme;) Tj
T*
(    }) Tj
T*
(}) Tj
T*
(```) Tj
T*
() Tj
T*
(Enable site:) Tj
T*
(```bash) Tj
T*
(sudo ln -s /etc/nginx/sites-available/odoo19 /etc/nginx/sites-enabled/) Tj
T*
(sudo nginx -t) Tj
T*
(sudo systemctl restart nginx) Tj
T*
(```) Tj
T*
() Tj
T*
(---) Tj
T*
() Tj
T*
(## 13\) Enable SSL with Let's Encrypt \(Optional, Recommended\)) Tj
T*
(```bash) Tj
T*
(sudo apt install -y certbot python3-certbot-nginx) Tj
T*
(sudo certbot --nginx -d your-domain.com) Tj
ET
endstream
endobj
