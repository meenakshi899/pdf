<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_access_role_tree" model="ir.ui.view">
        <field name="name">access.role.tree</field>
        <field name="model">access.role</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="group_ids" widget="many2many_tags"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_access_role_form" model="ir.ui.view">
        <field name="name">access.role.form</field>
        <field name="model">access.role</field>
        <field name="arch" type="xml">
            <form string="Access Role">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Role name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="group_ids" widget="many2many_tags"/>
                            <field name="active"/>
                        </group>
                        <group string="Options">
                            <field name="disable_chatter"/>
                            <field name="disable_debug_mode"/>
                            <field name="make_system_readonly"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Hide Menu">
                            <field name="hide_menu_line_ids">
                                <tree editable="bottom">
                                    <field name="menu_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Hide Any Button or Tab">
                            <field name="hide_button_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"/>
                                    <field name="button_name"/>
                                    <field name="tab_name"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Hide Any Filter or GroupBy">
                            <field name="hide_filter_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"/>
                                    <field name="filter_name"/>
                                    <field name="groupby_name"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Edit Fields Access">
                            <field name="edit_field_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"/>
                                    <field name="field_id"/>
                                    <field name="readonly"/>
                                    <field name="invisible"/>
                                    <field name="required"/>
                                    <field name="remove_external_link"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Edit Model Access">
                            <field name="model_access_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"/>
                                    <field name="readonly"/>
                                    <field name="hide_create"/>
                                    <field name="hide_delete"/>
                                    <field name="hide_archive"/>
                                    <field name="hide_export"/>
                                    <field name="hide_duplicate"/>
                                    <field name="hide_report"/>
                                    <field name="hide_actions"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Edit Domain Access">
                            <field name="domain_access_line_ids">
                                <tree editable="bottom">
                                    <field name="model_id"/>
                                    <field name="domain"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Users">
                            <field name="user_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_access_role" model="ir.actions.act_window">
        <field name="name">Access Roles</field>
        <field name="res_model">access.role</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_access_role_root" name="Access Role" parent="base.menu_custom" sequence="50"/>
    <menuitem id="menu_access_role" name="Role Management" parent="menu_access_role_root" action="action_access_role"/>
</odoo>
