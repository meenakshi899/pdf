<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_access_role" model="ir.ui.view">
        <field name="name">res.users.form.access.role</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']/group" position="inside">
                <group string="Access Roles">
                    <field name="access_role_ids" widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
